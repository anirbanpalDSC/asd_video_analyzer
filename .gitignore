# File types to ignore
*.mp4
*.mp3
*.pyc

# Files to ignore
.env
.claude/settings.local.json
.streamlit/config.toml

# Directories to ignore
env/
__pycache__/
venv/
uploads/
processed/

# Project instructions
.claude/
copilot-instructions.md
whisper_cache/

# Model weights (large binary files)
models/*.pkl
models/**/*.pkl

# Partial download artifacts
models/**/*.part

# YOLOv8 / PyTorch exported weights
models/**/*.pt
models/**/*.pth

# MediaPipe task bundles
models/**/*.task
models/**/*.tflite

# ONNX exports
models/**/*.onnx

# Exclude entire downloaded weight subdirectories (e.g. MPIIGaze folds)
models/L2CSNet/
